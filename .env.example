# ─── Database ──────────────────────────────────────────────
# Local development (SQLite — no external DB required)
DATABASE_URL=sqlite+aiosqlite:///./syncboard.db

# Production (set by Render automatically)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ──────────────────────────────────────────────────
# Local dev origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production — set to your Netlify domain
# BACKEND_CORS_ORIGINS=https://your-app-name.netlify.app
